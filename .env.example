# ─────────────────────────────────────────────────────────────────
#  ClikClak — Variables d'environnement
#  Copier ce fichier en .env.local et renseigner les vraies valeurs.
#  Ne jamais committer .env.local
# ─────────────────────────────────────────────────────────────────

# URL publique du site (sans slash final)
NEXT_PUBLIC_SITE_URL=https://clikclak.ch

# ── Stripe ────────────────────────────────────────────────────────
# Clé publiable (préfixe pk_) — peut être exposée côté client
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Clé secrète (préfixe sk_) — UNIQUEMENT côté serveur, jamais dans un composant client
STRIPE_SECRET_KEY=sk_live_...

# Secret de validation des webhooks Stripe (section Webhooks du dashboard Stripe)
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Emails (Resend) ───────────────────────────────────────────────
# Clé API Resend — UNIQUEMENT côté serveur
RESEND_API_KEY=re_...

# Adresse email d'expédition (doit être vérifiée dans Resend)
CONTACT_FROM_EMAIL=noreply@clikclak.ch

# Adresse de réception des commandes et formulaires de contact
CONTACT_TO_EMAIL=info@clikclak.ch

# ── Analytics / Publicité ─────────────────────────────────────────
# Google Analytics 4
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Ads
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXXX

# Google Maps API (pages Contact / Atelier)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ── Chatbot ───────────────────────────────────────────────────────
# Clé Anthropic — UNIQUEMENT côté serveur (/api/chat)
ANTHROPIC_API_KEY=sk-ant-...

# ── Turnstile (Cloudflare) ────────────────────────────────────────
# Clé publique (côté client)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Clé secrète (côté serveur uniquement)
TURNSTILE_SECRET_KEY=
