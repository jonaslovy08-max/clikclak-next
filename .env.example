# ─────────────────────────────────────────────────────────────────
#  ClikClak — Variables d'environnement
#  Copier ce fichier en .env.local et renseigner les vraies valeurs.
#  Ne jamais committer .env.local
# ─────────────────────────────────────────────────────────────────

# ── Feature flags ─────────────────────────────────────────────────
# Shop en construction (false = boutique désactivée publiquement)
# Obligatoire — défaut sécurisé : false
SHOP_ENABLED=false

# Chatbot IA (false = chatbot silencieux)
# Obligatoire — défaut sécurisé : false
CHATBOT_ENABLED=false

# ── Anthropic ─────────────────────────────────────────────────────
# Clé API Anthropic — UNIQUEMENT côté serveur. Ne jamais préfixer NEXT_PUBLIC_.
# Obligatoire pour que le chatbot réponde (503 si absente).
ANTHROPIC_API_KEY=

# Modèle Anthropic utilisé par le chatbot (facultatif — défaut : claude-haiku-4-5-20251001)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Upstash Redis ──────────────────────────────────────────────────
# Obligatoires pour le rate limiting du chatbot et du formulaire de contact.
# Le chatbot et le formulaire retournent 503 si ces variables sont absentes.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sel HMAC pour la pseudonymisation des identifiants visiteurs.
# Chaîne aléatoire d'au moins 32 caractères — OBLIGATOIRE.
# Utiliser des valeurs différentes en local et en production.
CHATBOT_RATE_LIMIT_SALT=

# ── Stripe ────────────────────────────────────────────────────────
# Clé secrète (préfixe sk_) — UNIQUEMENT côté serveur
STRIPE_SECRET_KEY=

# Secret de validation des webhooks Stripe
STRIPE_WEBHOOK_SECRET=

# ── Emails (Resend) ───────────────────────────────────────────────
# Clé API Resend — UNIQUEMENT côté serveur
RESEND_API_KEY=

# Adresse email d'expédition (doit être vérifiée dans Resend)
CONTACT_FROM_EMAIL=noreply@clikclak.ch

# Adresse de réception générale des formulaires de contact
CONTACT_TO_EMAIL=info@clikclak.ch

# Destinataires spécifiques par type de formulaire (facultatif — fallback CONTACT_TO_EMAIL)
CONTACT_BUYBACK_EMAIL=
CONTACT_COURIER_EMAIL=
CONTACT_DEPANNAGE_EMAIL=

# ── Turnstile (Cloudflare anti-spam) ──────────────────────────────
# Clé secrète — côté serveur uniquement (obligatoire en production)
TURNSTILE_SECRET_KEY=

# Clé publique — côté client (obligatoire pour afficher le widget)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ── Google Maps ───────────────────────────────────────────────────
# Clé API publique — carte sur la page Contact
# Restreindre aux domaines autorisés dans Google Cloud Console
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ── Site ──────────────────────────────────────────────────────────
# URL publique du site (sans slash final)
NEXT_PUBLIC_SITE_URL=https://clikclak.ch

# ── Analytics (facultatif) ────────────────────────────────────────
# Interrupteur principal Analytics — "true" UNIQUEMENT en production clikclak.ch.
# Ne jamais définir en staging, preview ou localhost.
# Configurer dans Infomaniak → Variables d'environnement → Production uniquement.
NEXT_PUBLIC_ANALYTICS_ENABLED=

# ID de mesure Google Analytics 4 — ex: G-XXXXXXXXXX
# Ne définir qu'en production (même condition que NEXT_PUBLIC_ANALYTICS_ENABLED).
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# (Déprécié) Alias de NEXT_PUBLIC_GA_MEASUREMENT_ID — ne plus utiliser
# NEXT_PUBLIC_GA_ID=

# Si absent, Google Ads est inactif
NEXT_PUBLIC_GOOGLE_ADS_ID=

# ── Supabase (interface d'administration) ─────────────────────────
# URL publique du projet Supabase.
# Visible dans Supabase Dashboard → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Clé publique Supabase (Publishable key) — protégée par RLS.
# Sûre à exposer côté navigateur, mais ne donne accès qu'aux données
# autorisées par les politiques Row Level Security.
# Visible dans Supabase Dashboard → Project Settings → API → Publishable key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Clé secrète Supabase (Secret key) — contourne RLS.
# STRICTEMENT RÉSERVÉE au serveur (Server Actions, Route Handlers, scripts).
# Ne jamais importer dans un Client Component ('use client').
# Ne jamais exposer dans le bundle navigateur.
# Visible dans Supabase Dashboard → Project Settings → API → Secret key
SUPABASE_SECRET_KEY=

# ── Instagram Messaging (Meta) ────────────────────────────────────
# Intégration : Instagram API with Instagram Login
# Permissions requises : instagram_business_basic, instagram_business_manage_messages
#
# Token d'accès Instagram (Instagram User Access Token).
# À contrôler et renouveler avant son expiration en production.
# Ne jamais journaliser ce token.
META_INSTAGRAM_ACCESS_TOKEN=

# Identifiant numérique du compte Instagram professionnel ClikClak.
# Utilisé comme endpoint d'envoi /{account_id}/messages.
META_INSTAGRAM_ACCOUNT_ID=

# Token de validation du webhook (valeur arbitraire choisie par vous, configurée dans Meta).
# Utilisé UNIQUEMENT pour répondre au challenge GET de vérification du webhook.
# Ne jamais utiliser comme secret HMAC pour valider des requêtes POST.
META_INSTAGRAM_WEBHOOK_VERIFY_TOKEN=

# Secret général de l'application Meta (App Secret).
# Utilisé pour (compatibilité) : validation X-Hub-Signature-256 des webhooks Post,
# validation des signed_request (désautorisation, suppression des données).
# Pour les webhooks Instagram Business Login, META_INSTAGRAM_CLIENT_SECRET est essayé en premier.
META_INSTAGRAM_APP_SECRET=

# Version de l'API Graph Meta (optionnel — défaut : v25.0)
META_GRAPH_API_VERSION=v25.0

# ── Instagram Business Login (OAuth) ──────────────────────────────
# ID de l'application Instagram (visible dans Meta for Developers → votre app → Instagram).
# Distinct de META_INSTAGRAM_ACCOUNT_ID (qui est l'identifiant du compte professionnel).
META_INSTAGRAM_APP_ID=

# Clé secrète Instagram associée à l'Instagram App ID (Instagram Client Secret).
# Visible dans Meta for Developers → votre app → Instagram → Configuration de l'API.
# Utilisée pour :
#   - échange code → token courte durée (POST api.instagram.com/oauth/access_token)
#   - échange token courte durée → longue durée (GET graph.instagram.com/access_token)
#   - validation X-Hub-Signature-256 des webhooks Instagram Business Login (priorité 1)
#   - validation des signed_request (désautorisation, suppression des données)
# Ne jamais journaliser. Ne jamais utiliser le préfixe NEXT_PUBLIC_.
META_INSTAGRAM_CLIENT_SECRET=

# Secret de la route de nettoyage GET /api/meta/instagram/cleanup.
# Valeur arbitraire longue et aléatoire — à configurer dans le cron job Infomaniak.
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
META_INSTAGRAM_CLEANUP_SECRET=

# URI de redirection OAuth enregistrée exactement dans les paramètres Meta de l'application.
# Exemple : https://clikclak.ch/api/meta/instagram/oauth/callback
# Doit correspondre caractère par caractère à la valeur configurée dans Meta.
META_INSTAGRAM_OAUTH_REDIRECT_URI=

# Clé de chiffrement AES-256 pour les access tokens Instagram stockés en base.
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# 32 octets encodés en base64 — strictement serveur, jamais exposé.
META_INSTAGRAM_TOKEN_ENCRYPTION_KEY=

# Les valeurs réelles doivent être placées dans .env.local localement.
# Ne pas configurer chez Infomaniak pendant la Phase 0 :
# ajouter ces variables en production uniquement quand /admin sera déployé.
